{
  "manifest_version": 3,
  "name": "Vocab Review Capture",
  "version": "0.1.1",
  "description": "Save English words and phrases into your review library.",
  "permissions": ["activeTab", "storage", "contextMenus", "scripting"],
  "host_permissions": ["__API_HOST_PERMISSION__"],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture vocabulary"
  },
  "content_scripts": []
}
